# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA commite o .env com valores de produção.

# ---- Banco de dados ----
# Local (com docker-compose): postgresql://fabelle:fabelle@localhost:5432/fabelle?schema=public
# Produção (Neon): pegar em https://console.neon.tech → sua database → Connection String
DATABASE_URL="postgresql://fabelle:fabelle@localhost:5432/fabelle?schema=public"

# ---- Auth ----
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="troque-por-um-segredo-aleatorio-de-48-bytes"

# ---- Servidor ----
# Porta do backend. Em prod, Render/Fly usam PORT — mas mantivemos BACKEND_PORT
# pra evitar conflito com o preview.
BACKEND_PORT=3001

# Origens permitidas para CORS (separadas por vírgula).
# Local: http://localhost:3002
# Prod: https://SEU-PROJETO.vercel.app,https://www.SEU-DOMINIO.com.br
FRONTEND_URL="http://localhost:3002"

# ---- Ambiente ----
# 'production' desativa o dev-link de recuperação de senha, etc.
NODE_ENV=development
